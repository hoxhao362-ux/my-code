async def author_login(
    request: LoginRequest,
    req: Request,
    session: AsyncSession = Depends(get_db_session),
):
    """作者登录接口 - 支持writer及以上角色登录"""
    # 获取客户端IP
    client_ip = req.client.host if req.client else "unknown"
    
    # 检查登录频率限制
