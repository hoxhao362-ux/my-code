    session: AsyncSession = Depends(get_db_session),
):
    """
    稿件流转核心接口
    
    支持的动作：
    - save: 保存草稿
    - submit: 提交稿件
    - withdraw: 撤稿
    - screen: 初审筛选
    - assign: 分配审稿人
    - review: 提交评审意见
    - decide: 编辑决策（需要 decision_type: accept/reject/revision/transfer）
    - revise: 提交修改稿
