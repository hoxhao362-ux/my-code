                     >
                       Review Transfer
                     </button>
                     <!-- Legacy Recommend Reviewers (if needed, otherwise hide or rename) -->
                     <!-- <button class="action-btn" @click="openReviewerModal(manuscript)">Recommend Reviewers</button> -->
                   </div>
                </div>
              </div>
            </div>
          </transition>
      </div>
    </main>

