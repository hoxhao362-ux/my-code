  contactEmail: '',
  contactPhone: '',
  copyrightInfo: ''
})

// 组件挂载时，从userStore加载配置数据
onMounted(() => {
  // 从userStore获取配置数据
  basicConfig.value = {
    ...userStore.basicConfig
  }
})

const saveConfig = () => {
  userStore.setBasicConfig(basicConfig.value)
  toastStore.add({ message: t('notification.basicConfig.actions.saveSuccess'), type: 'success' })
}

const resetConfig = () => {
  const defaultConfig = {
    platformName: 'Peerex Peer',
    platformLogo: '',
