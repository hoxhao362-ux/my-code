            <th>Duration</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="r in reviewers" :key="r.id" class="hover-row">
            <td class="bold-text">{{ r.anon_id }}</td>
            <td>{{ r.discipline }}</td>
            <td>{{ r.completed }}</td>
            <td>{{ r.current_task }}</td>
            <td>{{ r.submitted_at }}</td>
            <td>{{ r.duration }}</td>
